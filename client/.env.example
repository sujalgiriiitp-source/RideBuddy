# ============================================================================
# RIDEBUDDY FRONTEND (VERCEL) CONFIGURATION
# ============================================================================

# Development: Local proxy (vite.config.js proxies /api to backend)
VITE_API_URL=/api

# Vite dev server proxy target
VITE_PROXY_TARGET=http://localhost:5001

# Native app (Capacitor) API URL - for mobile apps
# Leave empty if not using Capacitor, or set to your backend URL
VITE_NATIVE_API_URL=https://your-backend-domain.com/api

# ============================================================================
# PRODUCTION DEPLOYMENT ON VERCEL
# ============================================================================
# Set VITE_API_URL on Vercel dashboard to your Azure backend URL:
# VITE_API_URL=https://your-azure-backend.azurewebsites.net/api
#
# This tells the Vercel-deployed app where to find your backend
# ============================================================================
